SSING_IMAGE=your-dockerhub-namespace/ssing-server:dev-latest
SPRING_PROFILES_ACTIVE=dev

SSING_DATASOURCE_URL=jdbc:mysql://your-rds-endpoint:3306/ssing?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
SSING_DATASOURCE_USERNAME=ssing
SSING_DATASOURCE_PASSWORD=change-me
SSING_JPA_DDL_AUTO=validate

SSING_JWT_SECRET=change-me-to-a-long-random-secret
SSING_KAKAO_APP_ID=change-me-to-kakao-app-id
# 도메인 구매 전 IP-only 임시 배포는 :80을 사용한다.
# 도메인 연결 후에는 dev-api.example.com처럼 실제 도메인을 사용한다.
SSING_DEV_DOMAIN=:80

JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=40.0

SENTRY_DSN=change-me-to-sentry-dsn
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=ssing-server@dev-local
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.0
