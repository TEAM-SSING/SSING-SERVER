<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="ssing-server"/>
    <springProperty name="ENV" source="spring.profiles.active" defaultValue="local"/>

    <!-- 테스트 로그는 실패 원인 확인에 필요한 최소 수준만 남긴다. -->
    <springProfile name="test">
        <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} request_id=%X{request_id:-} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
    </springProfile>

    <!-- local/dev/prod는 운영 정책에 맞춰 JSON 구조화 로그를 사용한다. -->
    <springProfile name="!test">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp/>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <message/>
                    <keyValuePairs/>
                    <mdc>
                        <includeMdcKeyName>request_id</includeMdcKeyName>
                    </mdc>
                    <stackTrace/>
                    <globalCustomFields>
                        <customFields>{"service":"${APP_NAME}","env":"${ENV}"}</customFields>
                    </globalCustomFields>
                </providers>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>
</configuration>
