<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="ssing-server"/>
    <springProperty name="ENV" source="spring.profiles.active" defaultValue="local"/>

    <!-- local/test 로그는 개발자가 바로 읽기 쉬운 텍스트 형식으로 출력한다. -->
    <springProfile name="local | test">
        <appender name="CONSOLE_PRETTY" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) request_id=%X{request_id:-} - %msg %kvp%n%ex</pattern>
            </encoder>
        </appender>
    </springProfile>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PRETTY"/>
        </root>
    </springProfile>

    <!-- test 로그는 local과 같은 읽기 쉬운 형식을 쓰되, 노이즈를 줄이기 위해 WARN 이상만 남긴다. -->
    <springProfile name="test">
        <root level="WARN">
            <appender-ref ref="CONSOLE_PRETTY"/>
        </root>
    </springProfile>

    <!-- dev/prod는 운영 정책에 맞춰 JSON 구조화 로그를 사용한다. -->
    <springProfile name="dev | prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp/>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <message/>
                    <keyValuePairs/>
                    <mdc>
                        <includeMdcKeyName>request_id</includeMdcKeyName>
                    </mdc>
                    <stackTrace/>
                    <globalCustomFields>
                        <customFields>{"service":"${APP_NAME}","env":"${ENV}"}</customFields>
                    </globalCustomFields>
                </providers>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>
</configuration>
